{
  "name": "workout-tracker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:test": "drizzle-kit migrate --config=drizzle.config.test.ts",
    "import": "tsx scripts/import-xlsx.ts",
    "normalize": "tsx scripts/normalize-exercises.ts",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@pinia/nuxt": "^0.11.3",
    "@telegram-apps/sdk": "^3.11.8",
    "drizzle-orm": "^0.36.0",
    "nuxt": "^4.0.0",
    "pinia": "^3.0.4",
    "postgres": "^3.4.4",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@pinia/testing": "^1.0.3",
    "@types/node": "^22.0.0",
    "@vue/test-utils": "^2.4.11",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.28.0",
    "exceljs": "^4.4.0",
    "happy-dom": "^20.10.6",
    "sass": "^1.101.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0"
  }
}
