# ── Прод-окружение «Твой Подход». Скопировать в .env рядом с docker-compose.prod.yml ──
NODE_ENV=production

# Postgres — контейнер, доступен ТОЛЬКО внутри сети compose (на хост порт не публикуется)
POSTGRES_USER=workout
POSTGRES_PASSWORD=ЗАМЕНИ_на_длинный_случайный_пароль
POSTGRES_DB=workout
# host = db (имя сервиса в compose-сети), НЕ localhost
DATABASE_URL=postgres://workout:ЗАМЕНИ_на_длинный_случайный_пароль@db:5432/workout

# Порт приложения на localhost. ОБЯЗАТЕЛЬНО проверь, что свободен:  ss -ltn | grep 8793
APP_PORT=8793

# Telegram-бот (создать в @BotFather — см. DEPLOY.md)
BOT_TOKEN=
BOT_USERNAME=
# Разрешённые Telegram-ID через запятую. ПУСТО = пускать всех (для закрытого круга лучше указать ID).
ALLOWLIST=

# AUTH_DEV_USER_ID в проде НЕ задавать (в production dev-обход авторизации всё равно выключен).
